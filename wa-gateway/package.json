{
  "name": "wa-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "WhatsApp Gateway menggunakan Baileys untuk presensi-medis-pintar",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
